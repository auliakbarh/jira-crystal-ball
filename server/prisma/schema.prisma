generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth — simple email/password login. A user may belong to many squads.
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// A squad/team. Everything below is scoped to a squad so multiple teams can
// use the same dashboard independently.
// ---------------------------------------------------------------------------
model Squad {
  id             String   @id @default(cuid())
  name           String   @unique
  // Non-secret default board id / project key, used to pre-fill the JIRA form.
  defaultBoardId String?
  createdAt      DateTime @default(now())

  members  TeamMember[]
  sprints  Sprint[]
  holidays Holiday[]
  blockers Blocker[]
  logs     ActivityLog[]
}

// A live "standup in progress" lock. One active session per sprint: only the
// holder (matching leadKey) may edit; staleness (lastSeen) lets others take over
// after the lead closes their tab. Admins always bypass.
model StandupSession {
  id        String   @id @default(cuid())
  sprintId  String   @unique
  leadName  String
  leadKey   String
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
}

// Completed standup sessions — duration log per squad/board.
model StandupLog {
  id          String   @id @default(cuid())
  squadId     String
  sprintId    String?
  leadName    String
  startedAt   DateTime
  endedAt     DateTime
  durationSec Int

  @@index([squadId, startedAt])
}

// Activity log of standup/board updates, shown on the Current Sprint screen.
model ActivityLog {
  id        String   @id @default(cuid())
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId   String
  sprintId  String?
  actor     String
  ticketKey String?
  message   String
  prevText  String?  // previous standup note (before this update)
  newText   String?  // new standup note (after this update)
  createdAt DateTime @default(now())

  @@index([squadId, createdAt])
}

enum Position {
  FE
  BE
  QA
  PM
}

enum LeaveType {
  CUTI
  SAKIT
  IZIN
}

model TeamMember {
  id             String   @id @default(cuid())
  squad          Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId        String
  name           String
  position       Position
  jiraAccountId  String?  // optional, to match JIRA assignee
  createdAt      DateTime @default(now())

  leaves            Leave[]      @relation("MemberLeaves")
  substituteLeaves  Leave[]      @relation("SubstituteLeaves")

  @@index([squadId])
}

// Leave / cuti with a date range and an optional substitute member.
model Leave {
  id           String   @id @default(cuid())
  member       TeamMember @relation("MemberLeaves", fields: [memberId], references: [id], onDelete: Cascade)
  memberId     String
  type         LeaveType @default(CUTI)
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  substitute   TeamMember? @relation("SubstituteLeaves", fields: [substituteId], references: [id])
  substituteId String?
  note         String?

  @@index([memberId])
}

// Public holiday / hari libur, scoped per squad.
model Holiday {
  id      String   @id @default(cuid())
  squad   Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId String
  date    DateTime @db.Date
  name    String

  @@unique([squadId, date])
  @@index([squadId])
}

model Sprint {
  id        String   @id @default(cuid())
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId   String
  number    Int
  name      String?
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())

  entries  StandupEntry[]
  blockers Blocker[]

  @@unique([squadId, number])
  @@index([squadId])
}

// One row of the standup dashboard: a (sprint, date, ticket) cell-set.
model StandupEntry {
  id          String   @id @default(cuid())
  sprint      Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  sprintId    String
  date        DateTime @db.Date

  // Snapshot of JIRA ticket info (source of truth is the board, cached here).
  ticketKey   String
  ticketStatus String?
  ticketSummary String?
  ticketAssignee String?
  issueType   String?
  // Snapshot of grouping info so past sprints can group by epic/parent.
  epicKey     String?
  epicName    String?
  parentKey   String?
  parentName  String?
  carryOverCount Int?
  carryOverFrom  String? // comma-joined names of completed sprints, snapshot

  // Manually recorded contributors per discipline.
  feAssignee  String?
  beAssignee  String?
  qaAssignee  String?
  feProgress  Int      @default(0) // 0..100, per-assignee progress
  beProgress  Int      @default(0)
  qaProgress  Int      @default(0)

  updateText  String?  @default("")
  progress    Int      @default(0) // 0..100 (overall)
  blockerNote String?  @default("")

  updatedAt   DateTime @updatedAt

  @@unique([sprintId, date, ticketKey])
  @@index([sprintId, date])
}

// Blocker tracking. Kept in sync from StandupEntry.blockerNote but also
// editable on its own in the dashboard's blocker section.
model Blocker {
  id          String    @id @default(cuid())
  squad       Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId     String
  sprint      Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  sprintId    String?
  description String
  jiraTicket  String?
  foundDate   DateTime  @db.Date
  resolvedDate DateTime? @db.Date
  note        String?
  resolveNote String?   // note added when the blocker is resolved
  // Set when this blocker was auto-created from a standup entry, so edits sync.
  sourceEntryId String? @unique

  @@index([squadId])
}
