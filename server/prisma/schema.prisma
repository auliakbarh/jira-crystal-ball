generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth — simple email/password login. A user may belong to many squads.
// ---------------------------------------------------------------------------
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// A squad/team. Everything below is scoped to a squad so multiple teams can
// use the same dashboard independently.
// ---------------------------------------------------------------------------
model Squad {
  id             String   @id @default(cuid())
  name           String   @unique
  // Non-secret default board id / project key, used to pre-fill the JIRA form.
  defaultBoardId String?
  // Story Points fields (custom field id OR field name). Per role + default.
  spFieldDefault String?
  spFieldFE      String?
  spFieldBE      String?
  spFieldQA      String?
  // Per-squad Confluence export target (fallback: global env CONFLUENCE_SPACE_KEY/PARENT_ID).
  confluenceSpaceKey String?
  confluenceParentId String?
  // Tarot (planning poker) default story-point scale for this squad. A host can
  // override per-room and "set as default" → these fields. scaleValues = JSON
  // array of numbers used for CUSTOM (ignored for FIBONACCI/SCRUM presets).
  tarotScaleType   TarotScaleType?
  tarotScaleValues String?
  createdAt      DateTime @default(now())

  members    TeamMember[]
  sprints    Sprint[]
  holidays   Holiday[]
  blockers   Blocker[]
  logs       ActivityLog[]
  tarotRooms TarotRoom[]
  fortuneDrafts   FortuneDraft[]
  fortuneHistory  FortuneHistory[]
}

// ---------------------------------------------------------------------------
// Fortune — Gemini-powered ticket creator. Drafts (WIP) + history (log).
// Shared per-squad: any member sees them; delete gated to creator/super-admin.
// payload/turns/usage stored as JSON strings (shapes owned by the client).
// ---------------------------------------------------------------------------
model FortuneDraft {
  id            String   @id @default(cuid())
  squad         Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId       String
  createdById   String
  createdByName String
  mode          String   // single | epic | import
  summary       String
  payload       String   // JSON: { single } | { plan }
  requirementText String?
  turns         String?  // JSON: [{ role, text }]
  usage         String?  // JSON: usage snapshot
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([squadId, updatedAt])
}

// Global key/value app settings editable at runtime by admins (e.g. Gemini
// temperature). Env vars remain the default when a key is absent.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model FortuneHistory {
  id        String   @id @default(cuid())
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId   String
  actorId   String
  actorName String
  action    String   // generated | created | updated | reverted
  mode      String   // single | epic | import
  summary   String
  jiraKey   String?
  payload   String?  // JSON snapshot for recreate
  turns     String?  // JSON context
  usage     String?  // JSON usage
  createdAt DateTime @default(now())

  @@index([squadId, createdAt])
}

// A live "standup in progress" lock. One active session per sprint: only the
// holder (matching leadKey) may edit; staleness (lastSeen) lets others take over
// after the lead closes their tab. Admins always bypass.
model StandupSession {
  id        String   @id @default(cuid())
  sprintId  String   @unique
  leadName  String
  leadKey   String
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
}

// History of Confluence exports per sprint (each create/update keeps a link).
model ExportLog {
  id        String   @id @default(cuid())
  sprintId  String
  squadId   String
  pageId    String
  url       String
  action    String // "create" | "update"
  actor     String?
  createdAt DateTime @default(now())

  @@index([sprintId, createdAt])
}

// Completed standup sessions — duration log per squad/board.
model StandupLog {
  id          String   @id @default(cuid())
  squadId     String
  sprintId    String?
  leadName    String
  startedAt   DateTime
  endedAt     DateTime
  durationSec Int

  @@index([squadId, startedAt])
}

// Activity log of standup/board updates, shown on the Current Sprint screen.
model ActivityLog {
  id        String   @id @default(cuid())
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId   String
  sprintId  String?
  actor     String
  ticketKey String?
  message   String
  prevText  String?  // previous standup note (before this update)
  newText   String?  // new standup note (after this update)
  createdAt DateTime @default(now())

  @@index([squadId, createdAt])
}

enum Position {
  FE
  BE
  QA
  PM
  FULLSTACK
  ALL
}

enum LeaveType {
  CUTI
  SAKIT
  IZIN
}

model TeamMember {
  id             String   @id @default(cuid())
  squad          Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId        String
  name           String
  fullName       String?  // optional full/legal name (display); `name` is the short label
  position       Position
  jiraAccountId  String?  // optional, to match JIRA assignee
  createdAt      DateTime @default(now())

  leaves            Leave[]      @relation("MemberLeaves")
  substituteLeaves  Leave[]      @relation("SubstituteLeaves")
  moods             MoodEntry[]

  @@index([squadId])
}

// Leave / cuti with a date range and an optional substitute member.
model Leave {
  id           String   @id @default(cuid())
  member       TeamMember @relation("MemberLeaves", fields: [memberId], references: [id], onDelete: Cascade)
  memberId     String
  type         LeaveType @default(CUTI)
  startDate    DateTime @db.Date
  endDate      DateTime @db.Date
  substitute   TeamMember? @relation("SubstituteLeaves", fields: [substituteId], references: [id])
  substituteId String?
  note         String?

  @@index([memberId])
}

// Public holiday / hari libur, scoped per squad.
model Holiday {
  id      String   @id @default(cuid())
  squad   Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId String
  date    DateTime @db.Date
  name    String

  @@unique([squadId, date])
  @@index([squadId])
}

model Sprint {
  id        String   @id @default(cuid())
  squad     Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId   String
  number    Int
  name      String?
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  createdAt DateTime @default(now())

  // Confluence export marker (set once a report page exists; reused to update it).
  confluencePageId     String?
  confluenceUrl        String?
  confluenceExportedAt DateTime?

  entries  StandupEntry[]
  blockers Blocker[]
  moods    MoodEntry[]

  @@unique([squadId, number])
  @@index([squadId])
}

// One row of the standup dashboard: a (sprint, date, ticket) cell-set.
model StandupEntry {
  id          String   @id @default(cuid())
  sprint      Sprint   @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  sprintId    String
  date        DateTime @db.Date

  // Snapshot of JIRA ticket info (source of truth is the board, cached here).
  ticketKey   String
  ticketStatus String?
  ticketSummary String?
  ticketAssignee String?
  issueType   String?
  storyPoints Float?
  // Snapshot of grouping info so past sprints can group by epic/parent.
  epicKey     String?
  epicName    String?
  parentKey   String?
  parentName  String?
  carryOverCount Int?
  carryOverFrom  String? // comma-joined names of completed sprints, snapshot

  // Manually recorded contributors per discipline.
  feAssignee  String?
  beAssignee  String?
  qaAssignee  String?
  feProgress  Int      @default(0) // 0..100, per-assignee progress
  beProgress  Int      @default(0)
  qaProgress  Int      @default(0)

  updateText  String?  @default("")
  progress    Int      @default(0) // 0..100 (overall)
  blockerNote String?  @default("")
  // Ticket put on hold during standup (blocked / deprioritized). Renders greyed out.
  hold        Boolean  @default(false)

  updatedAt   DateTime @updatedAt

  @@unique([sprintId, date, ticketKey])
  @@index([sprintId, date])
}

// Per-member daily mood during a sprint (Moon Phase). Scale 1 (worst) .. 5
// (best/happy); default 5 is a client-side fallback when no row exists.
model MoodEntry {
  id         String     @id @default(cuid())
  sprint     Sprint     @relation(fields: [sprintId], references: [id], onDelete: Cascade)
  sprintId   String
  member     TeamMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId   String
  memberName String     // snapshot for display resilience
  date       DateTime   @db.Date
  mood       Int        // 1..5
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([sprintId, memberId, date])
  @@index([sprintId, date])
  @@index([memberId])
}

// Blocker tracking. Kept in sync from StandupEntry.blockerNote but also
// editable on its own in the dashboard's blocker section.
model Blocker {
  id          String    @id @default(cuid())
  squad       Squad     @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId     String
  sprint      Sprint?   @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  sprintId    String?
  description String
  jiraTicket  String?
  foundDate   DateTime  @db.Date
  resolvedDate DateTime? @db.Date
  note        String?
  resolveNote String?   // note added when the blocker is resolved
  // Set when this blocker was auto-created from a standup entry, so edits sync.
  sourceEntryId String? @unique

  @@index([squadId])
}

// ---------------------------------------------------------------------------
// Tarot — planning poker. One ACTIVE room per squad. Host (creator) runs the
// session; guests join and vote. Live presence + votes pushed via subscriptions.
// ---------------------------------------------------------------------------
enum TarotRoomStatus {
  ACTIVE
  ENDED
}

enum TarotRoundStatus {
  VOTING   // cards face-down, participants picking
  REVEALED // all confirmed → cards flipped, host decides
  DECIDED  // story point set for this ticket
}

enum TarotScaleType {
  FIBONACCI
  SCRUM
  CUSTOM
}

model TarotRoom {
  id            String   @id @default(cuid())
  squad         Squad    @relation(fields: [squadId], references: [id], onDelete: Cascade)
  squadId       String
  name          String? // "<Squad> - Sprint Planning #<seq> - <date>"
  seq           Int      @default(1) // per-squad incrementing planning number
  hostName      String
  hostKey       String // client-held host token (host may be a guest, not a User)
  status        TarotRoomStatus @default(ACTIVE)
  scaleType     TarotScaleType  @default(FIBONACCI)
  scaleValues   String // JSON array of numeric values (the deck for this room)
  currentRoundId String? // active round (ticket currently being voted), if any
  sprintName    String?
  createdAt     DateTime @default(now())
  endedAt       DateTime?

  participants TarotParticipant[]
  rounds       TarotRound[]
  results      TarotResult[]

  @@index([squadId, status])
}

// A room participant. Rows are kept after leaving for the attendance log.
model TarotParticipant {
  id       String   @id @default(cuid())
  room     TarotRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId   String
  name     String
  key      String // client-held participant token (identity across reconnect)
  isHost   Boolean  @default(false)
  joinedAt DateTime @default(now())
  lastSeen DateTime @default(now())
  leftAt   DateTime?
  kicked   Boolean  @default(false)

  votes TarotVote[]

  @@unique([roomId, key])
  @@index([roomId])
}

// One voting cycle for a ticket. Re-voting ("next cycle") creates a new round.
model TarotRound {
  id             String   @id @default(cuid())
  room           TarotRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId         String
  ticketKey      String
  ticketSummary  String?
  ticketType     String?
  ticketPriority String?
  ticketUrl      String?
  parentKey      String?
  parentName     String?
  status         TarotRoundStatus @default(VOTING)
  cycle          Int      @default(1)
  createdAt      DateTime @default(now())

  votes TarotVote[]

  @@index([roomId, ticketKey])
}

model TarotVote {
  id              String   @id @default(cuid())
  round           TarotRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId         String
  participant     TarotParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId   String
  participantName String
  value           String  // numeric as string, or "?" / "coffee"
  confirmed       Boolean  @default(false)
  updatedAt       DateTime @updatedAt

  @@unique([roundId, participantId])
  @@index([roundId])
}

// Decided story point per ticket per room (history). effort = ticket point;
// per-role points each capped at effort.
model TarotResult {
  id            String   @id @default(cuid())
  room          TarotRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  roomId        String
  ticketKey     String
  ticketSummary String?
  parentKey     String?
  parentName    String?
  effort        Float
  pointFE       Float?
  pointBE       Float?
  pointQA       Float?
  decidedAt     DateTime @default(now())
  // Jira sync: snapshot of prior field values (JSON) so a reset can restore them.
  jiraPrevValues String?
  syncedAt      DateTime?

  @@unique([roomId, ticketKey])
  @@index([roomId])
}
