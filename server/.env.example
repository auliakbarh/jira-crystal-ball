# PostgreSQL connection (matches docker-compose.yml)
DATABASE_URL="postgresql://jcb:jcb_password@localhost:5432/jira_crystal_ball?schema=public"

# JWT signing secret — CHANGE THIS in production.
# Generate a strong one, e.g.:  openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string"

# HTTP port for the Apollo GraphQL server
PORT=4000

# production enables the CORS allow-list below; anything else = dev (permissive).
NODE_ENV="development"
# Comma-separated browser origins allowed in production (HTTP + WebSocket).
# Empty in production → browser cross-origin requests are blocked (warning logged).
# Ignored in development. e.g. CORS_ORIGINS="https://app.example.com,https://admin.example.com"
CORS_ORIGINS=""

# Optional: Redis for GraphQL subscriptions across MULTIPLE server instances
# (horizontal scale). Blank → in-memory pub/sub (single instance only).
REDIS_URL=""                    # e.g. redis://localhost:6379

# Seed admin credentials (used by `npm run db:seed`).
# SEED_ADMIN_EMAIL also designates the "super admin" — the only account allowed to
# manage other admins (Settings → Admin Accounts). Keep it in sync with the seeded user.
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="admin123"
SEED_ADMIN_NAME="Admin"

# ---------------------------------------------------------------------------
# JIRA connection (global). Per-squad only the board id differs (set per squad
# in the UI; stored as Squad.defaultBoardId). Board id is optional.
# ---------------------------------------------------------------------------
JIRA_BASE_URL="https://your-org.atlassian.net"
JIRA_EMAIL="you@your-org.com"
JIRA_API_TOKEN="your-atlassian-api-token"
# Optional: store the token encrypted at rest instead of the plaintext above.
# Leave JIRA_API_TOKEN blank and set both of these (plaintext wins if present).
# Generate the ciphertext:  JIRA_ENC_KEY="..." npm run token:encrypt -- "<token>"
JIRA_API_TOKEN_ENC=""
JIRA_ENC_KEY=""                 # decryption passphrase (keep in a secrets manager)
# Optional fallback board id / project key when a squad has none:
JIRA_DEFAULT_BOARD_ID=""
# Optional JQL override for fetching board issues:
JIRA_JQL=""
# Story Points custom field id (find via /rest/api/3/field; Cloud default below):
JIRA_STORY_POINTS_FIELD="customfield_10016"

# Confluence export (defaults to the JIRA site/credentials above).
CONFLUENCE_BASE_URL=""          # blank → uses JIRA_BASE_URL
CONFLUENCE_SPACE_KEY=""         # space key to create pages in (…/wiki/spaces/<KEY>/…)
CONFLUENCE_PARENT_ID=""         # parent page/folder id (…/folder/<id>/…)

# Tarot (planning poker)
TAROT_ROOM_RETENTION_DAYS="30"  # auto-purge ended rooms older than N days (0 = keep forever)

# Log retention: purge ActivityLog / StandupLog older than N days (0 = keep forever)
LOG_RETENTION_DAYS="0"

# Fortune (Gemini ticket creator). Plaintext key wins; else encrypted (like JIRA):
#   ENC_KEY="..." npm run token:encrypt -- "<gemini-key>" GEMINI_API_KEY_ENC
GEMINI_API_KEY=""               # Google AI Studio API key
GEMINI_API_KEY_ENC=""           # OR encrypted key (with GEMINI_ENC_KEY)
GEMINI_ENC_KEY=""               # decryption passphrase for GEMINI_API_KEY_ENC
GEMINI_MODEL="gemini-2.5-flash" # default model (users can pick per-draft in the UI)
GEMINI_TEMPERATURE="0.2"        # default sampling temperature (admins can override in Settings)
GEMINI_FX_IDR="16000"           # USD→IDR rate for the estimated-cost display
FORTUNE_HISTORY_RETENTION_DAYS="90" # auto-purge Fortune history older than N days (0 = keep forever)
